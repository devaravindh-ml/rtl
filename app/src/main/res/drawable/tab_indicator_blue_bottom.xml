<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <item
        android:top="-4dp"
        android:left="-4dp"
        android:right="-4dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="3dp"
                android:color="#3B82F6" /> </shape>
    </item>
</layer-list>